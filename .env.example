# ─────────────────────────────────────────────
# DGX Stack Configuration
# Copy to .env and edit, or run ./setup.sh
# ─────────────────────────────────────────────

# Model — pick one pair:
#   Gemma 4:  vllm/vllm-openai:gemma4-cu130 + google/gemma-4-26B-A4B-it
#   Qwen 3.5: vllm/vllm-openai:cu130-nightly + Qwen/Qwen3.5-35B-A3B
VLLM_IMAGE=vllm/vllm-openai:gemma4-cu130
HF_MODEL_ID=google/gemma-4-26B-A4B-it
SERVED_MODEL_NAME=gemma-4-26b
VLLM_EXTRA_FLAGS=--no-enable-prefix-caching

# For Qwen 3.5 instead, uncomment these and comment out the above:
# VLLM_IMAGE=vllm/vllm-openai:cu130-nightly
# HF_MODEL_ID=Qwen/Qwen3.5-35B-A3B
# SERVED_MODEL_NAME=qwen3.5-35b
# VLLM_EXTRA_FLAGS=--enable-prefix-caching --reasoning-parser qwen3

# HuggingFace (required for Gemma 4, optional for Qwen 3.5)
HF_TOKEN=hf_your_token_here
HF_CACHE=~/.cache/huggingface

# Network
VLLM_PORT=8000
OCR_PORT=8001

# GPU / Model
GPU_MEMORY_UTIL=0.75
MAX_MODEL_LEN=131072
MAX_NUM_SEQS=4
KV_CACHE_DTYPE=fp8        # fp8 for performance, auto (BF16) if fp8 causes errors

# OCR
OCR_CHUNK_SIZE=6
OCR_OVERLAP=2
OCR_DPI=200
OCR_MAX_TOKENS=16384
OCR_TEMPERATURE=0.1
OCR_MAX_CONCURRENT_CHUNKS=4
OCR_MAX_PAGES=200
OCR_MAX_FILE_SIZE_MB=100
